---
import "@/styles/global.css";
import NavBar from "@/components/NavBar";
import { BASE_URL } from "@/utils";

interface Props {
  title: string;
}
const { title } = Astro.props;
const user = Astro.locals.user;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href={`${BASE_URL}/godot/index.icon.png`} />
    <link rel="apple-touch-icon" href={`${BASE_URL}/godot/index.apple-touch-icon.png`} />
    <link rel="manifest" href={`${BASE_URL}/manifest.json`} />
    <meta name="theme-color" content="#111111" />
    <slot name="head" />
  </head>
  <body class="bg-black text-white m-0 overflow-hidden">
    <NavBar serverUser={user} client:load />
    <slot />
    <script is:inline define:vars={{ BASE_URL }}>
      if (location.hostname === "localhost") {
        setInterval(() => {
          fetch(BASE_URL + "/godot/index.pck", { cache: "no-store" })
            .then((res) => res.headers.get("last-modified"))
            .then((modified) => {
              if (window.lastGodotBuild && window.lastGodotBuild !== modified) {
                location.reload();
              }
              window.lastGodotBuild = modified;
            });
        }, 2000);
      }
    </script>
  </body>
</html>
