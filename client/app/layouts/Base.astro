---
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";
import NavBar from "@/components/NavBar.astro";
import { BASE_URL } from "@/utils";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <link
      rel="icon"
      type="image/png"
      href={`${BASE_URL}/godot/index.icon.png`}
    />

    <link
      rel="apple-touch-icon"
      href={`${BASE_URL}/godot/index.apple-touch-icon.png`}
    />

    <link rel="manifest" href={`${BASE_URL}/manifest.json`} />
    <meta name="theme-color" content="#111111" />
    <ClientRouter />
    <slot name="head" />
  </head>
  <body
    transition:animate="none"
    class="bg-black text-white m-0 overflow-hidden pt-12"
  >
    <NavBar />

    <slot />

    <!-- Dev-only Godot build watcher -->
    <script is:inline define:vars={{ BASE_URL }}>
      if (location.hostname === "localhost") {
        setInterval(() => {
          if (document.hidden || !navigator.onLine) return;

          fetch(BASE_URL + "/godot/index.pck", {
            method: "HEAD",
            cache: "no-store",
          })
            .then((res) => res.headers.get("last-modified"))
            .then((modified) => {
              if (window.lastGodotBuild && window.lastGodotBuild !== modified) {
                location.reload();
              }

              window.lastGodotBuild = modified;
            })
            .catch(() => {});
        }, 2000);
      }
    </script>

    <!-- Service worker handling -->
    <script is:inline define:vars={{ BASE_URL }}>
      if ("serviceWorker" in navigator) {
        const isDev =
          location.hostname === "localhost" ||
          location.hostname === "127.0.0.1";

        if (isDev) {
          // In dev, unregister service workers so stale caches do not affect
          // tutorial mode, sandbox mode, or Godot scene loading.
          navigator.serviceWorker.getRegistrations().then(async (regs) => {
            for (const reg of regs) {
              try {
                await reg.unregister();
              } catch {}
            }
          });
        } else {
          const swUrl = BASE_URL + "/sw.js";
          const swScope = BASE_URL + "/";
          const wantedScope = new URL(swScope, location.origin).href;

          navigator.serviceWorker.getRegistrations().then(async (regs) => {
            // Remove service workers registered under the wrong scope.
            for (const reg of regs) {
              if (reg.scope !== wantedScope) {
                try {
                  await reg.unregister();
                } catch {}
              }
            }

            try {
              await navigator.serviceWorker.register(swUrl, {
                scope: swScope,
              });
            } catch (err) {
              console.warn("SW registration failed:", err);
            }
          });
        }
      }
    </script>
  </body>
</html>