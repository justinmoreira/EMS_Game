---
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";
import AccountModal from "@/components/AuthPanel";
import { BASE_URL } from "@/utils";

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link
      rel="icon"
      type="image/png"
      href={`${BASE_URL}/godot/index.icon.png`}
    />
    <link
      rel="apple-touch-icon"
      href={`${BASE_URL}/godot/index.apple-touch-icon.png`}
    />
    <link rel="manifest" href={`${BASE_URL}/manifest.json`} />
    <meta name="theme-color" content="#111111" />
    <slot name="head" />
  </head>
  <body class="bg-black text-white m-0 overflow-hidden pt-12">
    <nav
      class="fixed top-0 left-0 right-0 z-50 bg-neutral-900/80 backdrop-blur-sm border-b border-neutral-700"
      transition:persist
    >
      <div class="relative flex items-center justify-between px-6 h-12">
        <a href={`${BASE_URL}/`} class="text-sm font-bold tracking-wide">
          EMS Sim
        </a>
        <div class="absolute left-1/2 -translate-x-1/2 flex items-center gap-6">
          <a
            href={`${BASE_URL}/play`}
            class="text-sm font-medium hover:text-white text-neutral-300 transition-colors"
          >
            Singleplayer
          </a>
          <a
            href={`${BASE_URL}/multiplayer`}
            class="text-sm font-medium hover:text-white text-neutral-300 transition-colors"
          >
            Multiplayer
          </a>
          <a
            href={`${BASE_URL}/leaderboards`}
            class="text-sm font-medium hover:text-white text-neutral-300 transition-colors"
          >
            Leaderboards
          </a>
        </div>
        <span
          id="account-placeholder"
          class="text-sm font-medium text-neutral-300 min-w-[70px] text-right"
        ></span>
        <script is:inline>
          try {
            var n = localStorage.getItem("account_display_name");
            if (n)
              document.getElementById("account-placeholder").textContent = n;
            else
              document.getElementById("account-placeholder").textContent =
                "Account";
          } catch {}
        </script>
        <AccountModal client:only="preact" />
      </div>
    </nav>
    <slot />
    <script>
      import { registerSW } from "virtual:pwa-register";

      if ("serviceWorker" in navigator) {
        // In dev, unregister ALL service workers so iteration isn't blocked by
        // a stale cached bundle from a previous prod build.
        if (import.meta.env.DEV) {
          (async () => {
            const regs = await navigator.serviceWorker.getRegistrations();
            const hadSW = regs.length > 0;
            for (const reg of regs) {
              try {
                await reg.unregister();
              } catch {}
            }
            let hadCache = false;
            if ("caches" in window) {
              const keys = await caches.keys();
              hadCache = keys.length > 0;
              await Promise.all(keys.map((k) => caches.delete(k)));
            }
            // If we just cleared a stale SW/cache, reload once so the user
            // doesn't have to. Use a session flag to avoid reload loops.
            if ((hadSW || hadCache) && !sessionStorage.getItem("__sw_cleared")) {
              sessionStorage.setItem("__sw_cleared", "1");
              location.reload();
            }
          })();
        } else {
          const wantedScope = new URL(
            import.meta.env.BASE_URL,
            location.origin,
          ).href;

          // Drop legacy SWs at a different scope (clears root-scope SWs from
          // earlier deploys that redirect-looped on /EMS_Game/* paths).
          navigator.serviceWorker.getRegistrations().then(async (regs) => {
            for (const reg of regs) {
              if (reg.scope !== wantedScope) {
                try {
                  await reg.unregister();
                } catch {}
              }
            }
            registerSW({ immediate: true });
          });
        }
      }
    </script>
  </body>
</html>
