---
import ResetPasswordForm from "@/components/ResetPasswordForm";
import Base from "@/layouts/Base.astro";
---

<Base title="Reset Password | GEMS">
  <div class="fixed inset-0 -z-10 bg-[#0a0a0a]"></div>

  <main class="flex h-[calc(100vh-3rem)] items-center justify-center px-6">
    <div class="w-full max-w-sm bg-neutral-900 border border-neutral-700 rounded-xl p-8">
      <h1 class="text-xl font-bold mb-6 text-white">Reset Password</h1>
      <ResetPasswordForm client:only="preact" />
    </div>
  </main>
</Base>
