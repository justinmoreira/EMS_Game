---
import Base from "@/layouts/Base.astro";
import { BASE_URL } from "@/utils";
---

<Base title="EMS Sim">
  <div id="vanta-bg" class="fixed inset-0 -z-10"></div>

  <div class="flex flex-col items-center justify-center h-screen gap-6">
    <h1 class="text-8xl font-black tracking-tighter text-white drop-shadow-lg">
      GEMS
    </h1>
    <p class="text-neutral-400 text-lg tracking-wide">
      Gamifying Electro-Magnetic Spectrum
    </p>
    <a
      href={`${BASE_URL}/play`}
      class="mt-4 px-8 py-3 bg-emerald-500 hover:bg-emerald-400 text-black font-semibold rounded-lg transition-colors"
    >
      Play Now
    </a>
  </div>

  <script
    is:inline
    src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"
    crossorigin="anonymous"></script>
  <script
    is:inline
    src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.net.min.js"
    crossorigin="anonymous"></script>
  <script is:inline>
    VANTA.NET({
      el: "#vanta-bg",
      mouseControls: true,
      touchControls: true,
      gyroControls: false,
      minHeight: 200.0,
      minWidth: 200.0,
      scale: 1.0,
      scaleMobile: 1.0,
      color: 0x58ff3f,
      backgroundColor: 0x0a0a0a,
      points: 8.0,
      maxDistance: 20.0,
      spacing: 18.0,
    });
  </script>
</Base>
