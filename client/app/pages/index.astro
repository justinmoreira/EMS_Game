---
import GemsTitle from "@/components/GemsTitle.astro";
import Base from "@/layouts/Base.astro";
import { BASE_URL } from "@/utils";
---

<Base title="EMS Sim">
  <div id="vanta-bg" transition:persist="vanta-bg" class="fixed inset-0 -z-10"></div>

  <GemsTitle>
    <a
      href={`${BASE_URL}/singleplayer`}
      class="pointer-events-auto inline-flex min-w-56 items-center justify-center rounded-xl bg-emerald-400 px-12 py-4 text-xl font-bold text-black shadow-lg shadow-emerald-950/50 transition-colors hover:bg-emerald-300"
    >
      Play Now
    </a>
  </GemsTitle>

  <script
    is:inline
    src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"
    crossorigin="anonymous"></script>
  <script
    is:inline
    src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.net.min.js"
    crossorigin="anonymous"></script>
  <script is:inline data-astro-rerun>
    // data-astro-rerun forces this inline script to re-execute on every
    // ClientRouter navigation. The canvas-presence guard skips re-init
    // when transition:persist on #vanta-bg has carried the WebGL canvas
    // across the nav. If the user came from a page without #vanta-bg
    // (e.g. /leaderboards 404), the persisted div was discarded and a
    // fresh one is rendered with no canvas — guard falls through and
    // Vanta initializes.
    //
    // Poll for VANTA: on swaps from a page that didn't load three/vanta
    // (e.g. /play → /), Astro inserts the <script src> tags but they're
    // still loading async when this rerun fires. Without the wait, VANTA
    // is undefined and the background stays black.
    (function init(attempt) {
      attempt = attempt || 0;
      if (typeof VANTA === "undefined") {
        if (attempt > 200) return; // give up after ~5s
        return setTimeout(() => init(attempt + 1), 25);
      }
      const el = document.getElementById("vanta-bg");
      if (!el || el.querySelector("canvas")) return;
      VANTA.NET({
        el,
        mouseControls: true,
        touchControls: true,
        gyroControls: false,
        minHeight: 200.0,
        minWidth: 200.0,
        scale: 1.0,
        scaleMobile: 1.0,
        color: 0x58ff3f,
        backgroundColor: 0x0a0a0a,
        points: 8.0,
        maxDistance: 20.0,
        spacing: 18.0,
      });
    })();
  </script>
</Base>