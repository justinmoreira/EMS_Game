---
import CoopLobby from "@/components/CoopLobby";
import Base from "@/layouts/Base.astro";
---

<Base title="Co-op Sandbox | EMS Sim">
  <div class="fixed inset-0 -z-10 bg-[#0a0a0a]"></div>

  <main class="mx-auto max-w-4xl px-6 pt-20 pb-12 text-white">
    <header class="mb-8">
      <h1 class="text-3xl font-bold">Co-op Sandbox</h1>
      <p class="mt-2 text-sm text-neutral-400">
        Build a scenario together in real time. Create a public room for anyone
        to join, or a private one you share by invite code. You both share full
        control of the same sandbox — place, move, and edit any unit, and see
        each other's changes live.
      </p>
    </header>

    <CoopLobby client:only="preact" />
  </main>
</Base>
