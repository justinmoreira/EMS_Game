---
import Base from "@/layouts/Base.astro";
import { Content, getHeadings } from "../../public/how_it_works.md";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface TocItem extends Heading {
  children: Heading[];
}

const toc: TocItem[] = getHeadings()
  .filter((h) => h.depth === 2 || h.depth === 3)
  .reduce((acc: TocItem[], heading: Heading) => {
    if (heading.depth === 2) {
      acc.push({ ...heading, children: [] });
    } else if (heading.depth === 3 && acc.length > 0) {
      acc[acc.length - 1].children.push(heading);
    }
    return acc;
  }, []);
---

<Base title="How It Works | GEMS">
    <div class="fixed inset-0 -z-10 bg-[#0a0a0a]"></div>

    <div class="h-[calc(100vh-3rem)] overflow-y-auto">
        <div class="flex justify-center px-4 pt-12 pb-16">
            <div class="flex gap-8 w-full max-w-6xl">
                <aside class="hidden lg:block w-72 shrink-0 self-start">
                    <nav
                        class="sticky top-12 space-y-2 text-sm bg-[#1a1a1a] border border-white/10 rounded-lg p-6"
                    >
                        {
                            toc.map(item => (
                                <div class="mb-6 last:mb-0">
                                    <a
                                        href={`#${item.slug}`}
                                        class="block text-emerald-400 hover:text-emerald-300 transition py-1 font-semibold"
                                    >
                                        {item.text}
                                    </a>
                                    {item.children.length > 0 && (
                                        <div class="pl-4 space-y-1 mt-2">
                                            {item.children.map(child => (
                                                <a
                                                    href={`#${child.slug}`}
                                                    class="block text-gray-400 hover:text-gray-300 transition text-xs py-0.5"
                                                >
                                                    {child.text}
                                                </a>
                                            ))}
                                        </div>
                                    )}
                                </div>
                            ))
                        }
                    </nav>
                </aside>
                <main class="how-it-works text-white w-full max-w-3xl flex-1">
                    <Content />
                </main>
            </div>
        </div>
    </div>
</Base>

<style is:global>
    .doc-scroll {
        scrollbar-width: thin;
        scrollbar-color: rgba(255, 255, 255, 0.18) transparent;
    }
    .doc-scroll::-webkit-scrollbar {
        width: 10px;
    }
    .doc-scroll::-webkit-scrollbar-track {
        background: transparent;
    }
    .doc-scroll::-webkit-scrollbar-thumb {
        background-color: rgba(255, 255, 255, 0.18);
        border-radius: 9999px;
        border: 2px solid transparent;
        background-clip: padding-box;
    }
    .doc-scroll::-webkit-scrollbar-thumb:hover {
        background-color: rgba(52, 211, 153, 0.6);
    }

    .how-it-works h1 {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        color: #fff;
    }

    .how-it-works > p:first-of-type {
        margin-bottom: 2rem;
        color: #a3a3a3;
    }

    .how-it-works h2 {
        font-size: 1.4rem;
        font-weight: 700;
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
        padding-bottom: 0.5rem;
        color: #6ee7b7;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .how-it-works h3 {
        font-size: 1.1rem;
        font-weight: 600;
        margin-top: 1.75rem;
        margin-bottom: 0.5rem;
        color: #34d399;
    }

    .how-it-works p {
        margin-bottom: 1rem;
        line-height: 1.7;
        color: #d4d4d4;
    }

    .how-it-works ul {
        margin: 0 0 1.25rem 1.25rem;
        list-style: disc;
        color: #d4d4d4;
    }

    .how-it-works li {
        margin-bottom: 0.4rem;
        line-height: 1.6;
    }

    .how-it-works li > ul {
        margin-top: 0.4rem;
    }

    .how-it-works strong {
        color: #fff;
        font-weight: 600;
    }

    .how-it-works code {
        background: rgba(255, 255, 255, 0.08);
        padding: 0.1rem 0.35rem;
        border-radius: 0.25rem;
        font-size: 0.85em;
        color: #6ee7b7;
    }

    .how-it-works pre {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 0.5rem;
        padding: 1rem;
        overflow-x: auto;
        margin-bottom: 1.5rem;
    }

    .how-it-works pre code {
        background: none;
        padding: 0;
        color: #d4d4d4;
    }

    .how-it-works hr {
        border-color: rgba(255, 255, 255, 0.1);
        margin: 2rem 0;
    }

    .how-it-works h2,
    .how-it-works h3 {
        scroll-margin-top: 4rem;
    }
</style>
