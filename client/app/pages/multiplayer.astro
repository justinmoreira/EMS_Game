---
import MultiplayerLobby from "@/components/MultiplayerLobby";
import Base from "@/layouts/Base.astro";
---

<Base title="Multiplayer | EMS Sim">
  <div class="fixed inset-0 -z-10 bg-[#0a0a0a]"></div>

  <main class="mx-auto max-w-4xl px-6 pt-20 pb-12 text-white">
    <header class="mb-8">
      <h1 class="text-3xl font-bold">Multiplayer</h1>
      <p class="mt-2 text-sm text-neutral-400">
        Create a public lobby for anyone to join, or a private one you share by
        invite code. Each turn you place a single unit; the match is won by the
        first — and only — side to bridge the immutable <span
          class="text-emerald-400">source</span
        > to the <span class="text-emerald-400">target</span> while denying your
        opponent.
      </p>
    </header>

    <MultiplayerLobby client:only="preact" />
  </main>
</Base>
