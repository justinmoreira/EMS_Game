---
import Base from '../layouts/Base.astro';
import NavBar from '../components/NavBar';
---
<Base title="Page Not Found">
  <NavBar client:load />
  <div class="flex flex-col items-center justify-center h-[calc(100vh-3rem)] mt-12">
    <h1 class="text-4xl font-bold">404 - Page Not Found</h1>
    <p class="mt-4 text-lg text-neutral-400">The page you requested does not exist.</p>
    <a href="/" class="mt-6 px-6 py-2 bg-emerald-500 text-black rounded-lg font-semibold">Go Home</a>
  </div>
</Base>
