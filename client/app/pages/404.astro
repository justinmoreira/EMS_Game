---
import Base from "@/layouts/Base.astro";
import { BASE_URL } from "@/utils";
---

<Base title="Page Not Found">
  <div class="fixed inset-0 -z-10 bg-[#0a0a0a]"></div>

  <div
    class="pointer-events-none fixed left-1/2 top-1/2 z-10 flex -translate-x-1/2 -translate-y-1/2 flex-col items-center gap-6 text-center"
  >
    <div>
      <h1
        class="text-4xl font-black tracking-tighter text-white drop-shadow-lg md:text-8xl"
      >
        404
      </h1>
      <p class="mt-2 text-lg tracking-wide text-neutral-400">
        This page doesn't exist
      </p>
    </div>
    <a
      href={`${BASE_URL}/`}
      class="pointer-events-auto inline-flex min-w-56 items-center justify-center rounded-xl bg-emerald-400 px-12 py-4 text-xl font-bold text-black shadow-lg shadow-emerald-950/50 transition-colors hover:bg-emerald-300"
    >
      Go Home
    </a>
  </div>
</Base>
