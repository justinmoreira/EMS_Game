[gd_resource type="Resource" script_class="UnitDefinition" format=3 uid="uid://bnb2ndvm2tkp4"]

[ext_resource type="Script" uid="uid://brvcwcd503l75" path="res://scenes/core/UnitDefinition.gd" id="def"]
[ext_resource type="Script" uid="uid://mdhqup6qxr0d" path="res://scenes/core/AttributeSpec.gd" id="spec"]

[sub_resource type="Resource" id="a_unit_name"]
script = ExtResource("spec")
id = &"unit_name"
display_name = "Name"
kind = 2
default_value = ""

[sub_resource type="Resource" id="a_sensitivity"]
script = ExtResource("spec")
id = &"sensitivity"
display_name = "Sensitivity"
max_value = 10.0
unit = "dBm"
default_value = 5

[sub_resource type="Resource" id="a_tuning"]
script = ExtResource("spec")
id = &"tuning_frequency"
display_name = "Tuning Frequency"
min_value = 30.0
max_value = 3000.0
unit = "MHz"
default_value = 1000

[sub_resource type="Resource" id="a_height"]
script = ExtResource("spec")
id = &"height"
display_name = "Height"
max_value = 10.0
unit = "m"
default_value = 5

[sub_resource type="Resource" id="a_bandwidth"]
script = ExtResource("spec")
id = &"sensor_bandwidth"
display_name = "Bandwidth"
kind = 4
enum_options = PackedStringArray("Narrow", "Medium", "Wide")
default_value = 1

[sub_resource type="Resource" id="a_scanning"]
script = ExtResource("spec")
id = &"is_scanning"
display_name = "Scanning"
kind = 3
default_value = true

[resource]
script = ExtResource("def")
id = &"sensor"
display_name = "Sensor"
group = &"sensors"
letter = "S"
color = Color(0.878, 0.6, 1, 1)
sprite_path = "res://assets/sprites/sensor.png"
animated_sprite_path = "res://assets/sprites/sensorAni.png"
attributes = Array[ExtResource("spec")]([SubResource("a_unit_name"), SubResource("a_sensitivity"), SubResource("a_tuning"), SubResource("a_height"), SubResource("a_bandwidth"), SubResource("a_scanning")])
