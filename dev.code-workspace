{
	"folders": [
		{
			"path": "."
		}
	],
	"settings": {
		"editor.formatOnSave": true,
		"editor.defaultFormatter": "biomejs.biome",
		"editor.tabSize": 2,
		"editor.insertSpaces": true,
		"files.trimTrailingWhitespace": true,

		"biome.lsp.bin": "/home/dev/.local/bin/biome",
		"editor.codeActionsOnSave": {
			"source.fixAll.biome": "always",
			"source.organizeImports.biome": "always"
		},
		"godotTools.editorPath.godot4": "${workspaceFolder}/scripts/godot4",
		"[astro]": {
			"editor.defaultFormatter": "astro-build.astro-vscode"
		},
		"[gdscript]": {
			"editor.defaultFormatter": "geequlim.godot-tools",
			"editor.tabSize": 4,
			"editor.insertSpaces": false
		},
		"vscode-just.justPath": "./scripts/just",
		"files.exclude": {
			".direnv/": true,
			".git/": true,
			// "EMS_Game.code-workspace": true,
			"flake.lock": true,
			".envrc": true,
			"**/.godot": true,
			// "dev.code-workspace": true,
			".vscode/": true,
			"**/.astro/": true,
			"**/node_modules/": true,
			"**/*.lock": true,
			".claude/": true,
			"biome.json": true,
		}
	}
}
